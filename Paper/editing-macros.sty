\newcommand{\red}[1]{\textcolor{red}{#1}}
\newcommand{\purple}[1]{\textcolor{purple}{#1}}
\definecolor{innerboxcolor}{rgb}{.9,.95,1}
\definecolor{outerlinecolor}{rgb}{.6,0,.2}
\definecolor{outerlinecoloreb}{rgb}{0,1,0}
\definecolor{innerboxcoloreb}{rgb}{1,1,1}

\newcommand{\sylong}[1]{\fcolorbox{outerlinecolor}{innerboxcolor}{
    \begin{minipage}{.9\textwidth}
      \red{\bf SY:} {#1}
  \end{minipage}} \\
}

\newcommand\sy[1]{\textcolor{red}{[SY: #1]}}

\newcommand{\hnlong}[1]{\fcolorbox{outerlinecolor}{innerboxcolor}{
    \begin{minipage}{.9\textwidth}
      \red{\bf HN:} {#1}
  \end{minipage}} \\
}

\makeatletter
\newcommand{\ablong}{\@ifstar{\ablong@hide}{\ablong@show}}

\newcommand{\ablong@show}[1]{%
  \par\noindent%
  \fcolorbox{outerlinecolor}{innerboxcolor}{%
    \begin{minipage}{.9\textwidth}%
      \red{\bfseries Ari:}~#1%
    \end{minipage}%
  }%
  \par\medskip%
}

\newcommand{\ablong@hide}[1]{%
  \ignorespaces% swallow argument, produce nothing
}
\makeatother

